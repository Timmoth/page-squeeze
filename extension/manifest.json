{
  "manifest_version": 3,
  "name": "page-squeeze",
  "version": "1.3",
  "description": "Squeezes webpages into clean markdown.",
  "permissions": [
    "activeTab",
    "scripting",
    "downloads",
    "clipboardWrite"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_height": 200,
    "max_height": 600
  },
  "icons": {
    "128": "icon.png"
  }
}
