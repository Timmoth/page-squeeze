{
  "manifest_version": 3,
  "name": "page-squeeze",
  "version": "1.2",
  "description": "Squeezes webpages into clean markdown.",
  "permissions": [
    "activeTab",
    "scripting",
    "downloads",
    "clipboardWrite"
  ],
  "icons": {
    "128": "icon.png"
  },
   "action": {
      "default_popup": "popup.html",
      "default_height": 200,
      "max_height": 600
    }
}